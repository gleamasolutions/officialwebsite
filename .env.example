# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=gleamasolutions@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

# Contact form recipient
CONTACT_RECEIVER=gleamasolutions@gmail.com

# Public site URL (used for canonical URLs, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://www.gleama.lk

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console HTML tag verification (optional)
NEXT_PUBLIC_GSC_VERIFICATION=your_google_site_verification_token

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id
